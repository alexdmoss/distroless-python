{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "constraints": {
    "python": "==3.13.*"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.gitlab-ci\\.yml$/",
        "/(^|/)([^/]*\\.)?Dockerfile$/"
      ],
      "matchStrings": [
        "PYTHON_VERSION:\\s*\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\"",
        "ARG PYTHON_VERSION=\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "python",
      "packageNameTemplate": "python",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["python"],
      "enabled": false
    },
    {
      "matchPackageNames": ["python"],
      "matchCurrentValue": "/^3\\.13\\./",
      "allowedVersions": "/^3\\.13\\./"
    },
    {
      "matchPackageNames": ["python"],
      "matchCurrentValue": "/^3\\.14\\./",
      "allowedVersions": "/^3\\.14\\./"
    }
  ]
}
